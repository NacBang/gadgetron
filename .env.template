# Gadgetron environment template.
#
# Copy this file to `.env` and replace the values for your machine:
#
#   cp .env.template .env
#
# Never commit `.env`. It may contain database passwords, OAuth secrets,
# bootstrap passwords, or API keys.
#
# Precedence: CLI flag > environment variable > gadgetron.toml > default.
# Full reference (consumer + default per variable):
# docs/manual/configuration.md §Environment variables.

# ---------------------------------------------------------------------------
# Core server
# ---------------------------------------------------------------------------

# PostgreSQL connection used by full DB mode. Unset/empty → no-db mode.
# Local demo example:
#   postgres://gadgetron:secret@127.0.0.1:5432/gadgetron_demo
GADGETRON_DATABASE_URL=postgres://gadgetron:secret@127.0.0.1:5432/gadgetron_demo

# Optional overrides — flags/toml usually cover these.
# GADGETRON_CONFIG=/etc/gadgetron/gadgetron.toml    # config file path (= --config)
# GADGETRON_BIND=0.0.0.0:18080                      # listen address (= --bind, overrides [server].bind)
# GADGETRON_PROVIDER=http://127.0.0.1:8000/v1       # zero-config single provider (= --provider)
# GADGETRON_DATA_DIR=/var/lib/gadgetron             # data home (default ~/.gadgetron)
# GADGETRON_BUNDLES_HOME=/var/lib/gadgetron/bundles # bundle store (wins over GADGETRON_DATA_DIR)

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------

# First-admin bootstrap password. Read ONLY while the `users` table is
# empty. The variable NAME is chosen in gadgetron.toml:
#   [auth.bootstrap]
#   admin_email = "admin@example.com"
#   admin_display_name = "Admin"
#   admin_password_env = "GADGETRON_ADMIN_PW"
GADGETRON_ADMIN_PW=change-me-before-first-boot

# Required only when [auth.google] is enabled in gadgetron.toml
# (`client_secret_env` names the variable; this is the conventional name).
# GADGETRON_GOOGLE_CLIENT_SECRET=replace-if-google-login-is-enabled

# ---------------------------------------------------------------------------
# Penny (agent backend)
# ---------------------------------------------------------------------------

# Extra PATH entries for the spawned CLI backend — claude/codex need
# node/npm on PATH when gadgetron runs under systemd or cron.
# GADGETRON_AGENT_NODE_PATH=/home/ops/.local/bin

# Destructive-tool (T3) confirmation token. Only consulted when
# [agent.gadgets.destructive] sets extra_confirmation = "env".
# GADGETRON_DESTRUCTIVE_TOKEN=I-UNDERSTAND-THIS-DELETES-DATA

# Optional rolling conversation-title summarizer. The key enables it;
# endpoint and model default to the local Gateway and "penny".
# GADGETRON_CONVERSATION_SUMMARY_KEY=gad_live_...
# GADGETRON_CONVERSATION_SUMMARY_GATEWAY=http://127.0.0.1:18080
# GADGETRON_CONVERSATION_SUMMARY_MODEL=penny

# ---------------------------------------------------------------------------
# Knowledge / wiki
# ---------------------------------------------------------------------------

# GADGETRON_KNOWLEDGE_WIKI_PATH=/var/lib/gadgetron/wiki
# GADGETRON_KNOWLEDGE_WIKI_AUTOCOMMIT=true
# GADGETRON_KNOWLEDGE_WIKI_GIT_AUTHOR="Penny <penny@example.com>"
# GADGETRON_KNOWLEDGE_WIKI_MAX_PAGE_BYTES=262144

# Web search (SearXNG) used by Penny research flows.
# GADGETRON_KNOWLEDGE_SEARCH_SEARXNG_URL=http://127.0.0.1:8888
# GADGETRON_KNOWLEDGE_SEARCH_TIMEOUT_SECS=10
# GADGETRON_KNOWLEDGE_SEARCH_MAX_RESULTS=8

# ---------------------------------------------------------------------------
# Server Administrator Bundle — legacy migration settings
#
# Core does not read these values. They remain documented while the
# pre-1.0 implementation moves behind the independent Bundle runtime.
# ---------------------------------------------------------------------------

# Background scans run automatically when the DB is up; set 0/false/no/off
# to keep only on-demand scans.
# GADGETRON_LOG_ANALYZER_AUTO=1

# Setting a key ENABLES the LLM classifier for error-ish lines that no
# rule matched (without it, rules-only). Gateway defaults to the local
# demo port; model defaults to "penny".
# GADGETRON_LOG_ANALYZER_KEY=gad_live_...
# GADGETRON_LOG_ANALYZER_GATEWAY=http://127.0.0.1:18080
# GADGETRON_LOG_ANALYZER_MODEL=penny

# Inventory + SSH keys directory (default ~/.gadgetron/server-monitor).
# GADGETRON_SERVER_MONITOR_HOME=/var/lib/gadgetron/server-monitor

# Factory-default password used once to push an SSH key to a gadgetini
# cooling board when none is supplied in the UI. Never stored.
# GADGETRON_GADGETINI_FACTORY_PASSWORD=factory-password

# ---------------------------------------------------------------------------
# Internal Penny → parent callback. `gadgetron serve` sets the URL and mints a
# turn-scoped delegated credential automatically. Do not set a static key for
# the normal service path. Standalone `gadgetron gadget serve` compatibility
# may use a dedicated OpenAiCompat key; never reuse an administrator key.
# ---------------------------------------------------------------------------
# GADGETRON_GATEWAY_CALLBACK_URL=
# GADGETRON_GATEWAY_CALLBACK_KEY=  # standalone compatibility only
# (GADGETRON_AGENT_GADGETS_JSON is a parent→child handshake; never set it.)

# ---------------------------------------------------------------------------
# Build / test only (not read at runtime) — see configuration.md
# ---------------------------------------------------------------------------
# GADGETRON_SKIP_WEB_BUILD=1     # cargo build: skip npm, embed fallback UI
# GADGETRON_WEB_TRUST_PATH=1     # cargo build: allow npm from inherited PATH
# GADGETRON_SKIP_POSTGRES_TESTS=1
# GADGETRON_TEST_DB_URL=postgres://...
# GADGETRON_TEST_KEY=gad_test_...
