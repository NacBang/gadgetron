# Gadgetron environment template.
#
# Copy this file to `.env` and replace the values for your machine:
#
#   cp .env.template .env
#
# Never commit `.env`. It may contain database passwords, OAuth secrets,
# bootstrap passwords, or API keys.

# PostgreSQL connection used by full DB mode.
# Local demo example:
#   postgres://gadgetron:secret@127.0.0.1:5432/gadgetron_demo
GADGETRON_DATABASE_URL=postgres://gadgetron:secret@127.0.0.1:5432/gadgetron_demo

# First-admin bootstrap password.
# `gadgetron.toml` should contain:
#   [auth.bootstrap]
#   admin_email = "admin@example.com"
#   admin_display_name = "Admin"
#   admin_password_env = "GADGETRON_ADMIN_PW"
#
# This value is read only when the `users` table is empty.
GADGETRON_ADMIN_PW=change-me-before-first-boot

# Optional: required only when `[auth.google]` is enabled in gadgetron.toml.
# Keep a placeholder if using scripts that require the variable to exist.
GADGETRON_GOOGLE_CLIENT_SECRET=replace-if-google-login-is-enabled

# Optional: lets log-analyzer callbacks reuse an existing admin-capable key.
# GADGETRON_LOG_ANALYZER_KEY=gad_live_...
