/target
*.swp
*.swo
.DS_Store
.env
*.log
*.pem
*.key
.gstack/
/.gadgetron/

# Local operator config — copy gadgetron.example.toml and customize.
/gadgetron.toml

# Local build env — holds per-host paths + sandbox secrets for demo.sh.
/.buildenv

# scripts/launch.sh writes the background-mode pidfile here.
/.gadgetron-serve.pid

# Tool-specific session state and native subagent adapters.
# Per AGENTS.md the project is tool-independent — adapters stay user-level
# (e.g. ~/.claude/agents/) and do not ship in the repo.
/.claude/

# graphify: cache directory + volatile scratch files regenerated on every
# commit / pull via the post-* hooks. The curated surfaces
# (`GRAPH_REPORT.md`, `graph.json`, `graph.html`) stay committed; the
# cache / scratch files do not — they produce diff churn on every commit
# without adding reviewable signal.
graphify-out/cache/
graphify-out/.graphify_*

# Ephemeral QA review artifacts. gstack `/design-review`, `/qa`, and
# related flows drop PNG screenshots at the repo root with names like
# `ui-<surface>-review.png`, and Playwright MCP caches console logs
# under `.playwright-mcp/`. Both are per-session scratch and should
# never end up in a commit — contributors can rerun the tool to
# regenerate.
ui-*-review.png
.playwright-mcp/

# Superpowers visual brainstorming companion session state.
.superpowers/
