# Incremental TypeScript build cache — regenerated by `tsc` on every
# run. Not part of the shipped product, no reason to track.
tsconfig.tsbuildinfo

# bun lockfile — the build pipeline (build.rs → npm ci) treats
# package-lock.json as authoritative. Contributors using bun can
# regenerate bun.lock locally; don't commit it.
bun.lock
